<div class="container account-form">
  <h1>Application {{ order.name }}</h1>
  <a href="{{ routes.account_url }}">&larr; Back to account</a>
  <p>Status: {{ order.fulfillment_status_label }}</p>
  <p>Submitted: {{ order.created_at | date: '%B %d, %Y' }}</p>
  <ul>
    {%- for line_item in order.line_items -%}
      <li>{{ line_item.title }}</li>
    {%- endfor -%}
  </ul>
</div>

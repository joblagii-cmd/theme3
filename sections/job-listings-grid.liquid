{%- liquid
  assign job_collection = collections[section.settings.collection]
-%}

<section class="job-listings container">
  {%- if section.settings.heading != blank -%}
    <h2 class="job-listings__heading">{{ section.settings.heading }}</h2>
  {%- endif -%}

  {%- if job_collection != blank and job_collection.products.size > 0 -%}
    <div class="job-listings__grid">
      {%- for product in job_collection.products limit: section.settings.jobs_to_show -%}
        {% render 'job-card', product: product %}
      {%- endfor -%}
    </div>

    {%- if section.settings.show_view_all -%}
      <div class="job-listings__view-all">
        <a href="{{ job_collection.url }}" class="btn btn--outline">View all jobs</a>
      </div>
    {%- endif -%}
  {%- else -%}
    <p class="job-listings__empty">No job listings yet. Add products to the selected collection to display them here.</p>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Job listings grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Latest job openings"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection to pull jobs from"
    },
    {
      "type": "range",
      "id": "jobs_to_show",
      "label": "Number of jobs to show",
      "min": 3,
      "max": 24,
      "step": 1,
      "default": 9
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'View all jobs' button",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Job listings grid"
    }
  ]
}
{% endschema %}

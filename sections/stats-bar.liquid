<section class="stats-bar">
  <div class="container stats-bar__inner">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'stat' -%}
          <div class="stats-bar__item">
            <span class="stats-bar__number">{{ block.settings.number }}</span>
            <span class="stats-bar__label">{{ block.settings.label }}</span>
          </div>
      {%- endcase -%}
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Stats bar",
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        { "type": "text", "id": "number", "label": "Number", "default": "1,200+" },
        { "type": "text", "id": "label", "label": "Label", "default": "Open jobs" }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "stat", "settings": { "number": "1,200+", "label": "Open jobs" } },
      { "type": "stat", "settings": { "number": "350+", "label": "Companies hiring" } },
      { "type": "stat", "settings": { "number": "40k+", "label": "Candidates" } },
      { "type": "stat", "settings": { "number": "98%", "label": "Response rate" } }
    ]
  }
}
{% endschema %}
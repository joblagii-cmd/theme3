<div class="container list-collections">
  <h1 class="list-collections__title">{{ section.settings.heading | default: "Browse by category" }}</h1>

  <div class="list-collections__grid">
    {%- for collection in collections -%}
      {%- unless collection.handle == 'frontpage' or collection.products.size == 0 -%}
        <a href="{{ collection.url }}" class="category-card">
          <h3 class="category-card__title">{{ collection.title }}</h3>
          <p class="category-card__count">{{ collection.products.size }} jobs</p>
        </a>
      {%- endunless -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Job categories list",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Browse by category"
    }
  ],
  "presets": [
    { "name": "Job categories list" }
  ]
}
{% endschema %}

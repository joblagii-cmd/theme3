<section class="featured-companies container">
  {%- if section.settings.heading != blank -%}
    <h2 class="featured-companies__heading">{{ section.settings.heading }}</h2>
  {%- endif -%}

  <div class="featured-companies__grid">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'company' -%}
          <div class="featured-companies__item">
            {%- if block.settings.logo != blank -%}
              <img src="{{ block.settings.logo | image_url: width: 160 }}" alt="{{ block.settings.name | escape }}" loading="lazy">
            {%- else -%}
              <span class="featured-companies__name">{{ block.settings.name }}</span>
            {%- endif -%}
          </div>
      {%- endcase -%}
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Featured companies",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Trusted by teams at" }
  ],
  "blocks": [
    {
      "type": "company",
      "name": "Company",
      "settings": [
        { "type": "text", "id": "name", "label": "Company name", "default": "Company" },
        { "type": "image_picker", "id": "logo", "label": "Logo" }
      ]
    }
  ]
}
{% endschema %}
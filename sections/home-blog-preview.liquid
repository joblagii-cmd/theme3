{%- liquid
  assign featured_blog = blogs[section.settings.blog]
-%}

<section class="home-blog container">
  <div class="home-blog__head">
    {%- if section.settings.heading != blank -%}
      <h2 class="home-blog__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="home-blog__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}
  </div>

  {%- if featured_blog != blank and featured_blog.articles.size > 0 -%}
    <div class="home-blog__grid">
      {%- for article in featured_blog.articles limit: section.settings.articles_to_show -%}
        <article class="blog-card">
          <a href="{{ article.url }}" class="blog-card__image-link">
            {%- if article.image -%}
              <img src="{{ article.image | image_url: width: 500 }}" alt="{{ article.title | escape }}" loading="lazy">
            {%- else -%}
              <div class="blog-card__image-placeholder"></div>
            {%- endif -%}
          </a>
          {%- if article.tags.size > 0 -%}
            <span class="blog-card__tag">{{ article.tags.first }}</span>
          {%- endif -%}
          <h3><a href="{{ article.url }}">{{ article.title }}</a></h3>
          <p class="blog-card__excerpt">{{ article.excerpt_or_content | strip_html | truncate: 130 }}</p>
          <div class="blog-card__meta">
            <span>{{ article.published_at | date: '%B %d, %Y' }}</span>
            {%- if article.author != blank -%}<span>&middot; {{ article.author }}</span>{%- endif -%}
          </div>
        </article>
      {%- endfor -%}
    </div>

    {%- if section.settings.show_view_all -%}
      <div class="home-blog__view-all">
        <a href="{{ featured_blog.url }}" class="btn btn--outline">View all articles</a>
      </div>
    {%- endif -%}
  {%- else -%}
    <p class="job-listings__empty">Add articles to your blog to feature them here.</p>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Blog preview",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Career advice & company news"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Tips, hiring trends, and updates from companies on the platform."
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog to feature"
    },
    {
      "type": "range",
      "id": "articles_to_show",
      "label": "Number of articles",
      "min": 3,
      "max": 12,
      "step": 1,
      "default": 6
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'View all articles' button",
      "default": true
    }
  ],
  "presets": [
    { "name": "Blog preview" }
  ]
}
{% endschema %}
